{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensentience.org/spec/skill-bundle/v0.1",
  "title": "SkillBundle v0.1",
  "description": "Portable artifact wrapping a SkillManifest, its source InteractionTrace, its first-class ProofResult, and an EvidenceBundle. Same JSON viewed two ways: SkillBundle for users, EvidenceBundle for evaluators.",
  "type": "object",
  "required": [
    "bundle_version",
    "bundle_id",
    "skill_id",
    "skill_version",
    "created_at",
    "workbench_version",
    "manifest",
    "interaction_trace",
    "proof",
    "evidence",
    "content_hash"
  ],
  "properties": {
    "bundle_version": { "const": "0.1.0" },
    "bundle_id":      { "type": "string", "format": "uuid" },
    "skill_id":       { "type": "string", "format": "uuid" },
    "skill_version":  { "type": "integer", "minimum": 1 },
    "created_at":     { "type": "string", "format": "date-time" },
    "workbench_version": { "type": "string" },
    "manifest":       { "$ref": "https://opensentience.org/spec/skill-manifest/v0.1" },
    "interaction_trace": {
      "type": "object",
      "description": "OS-011 §4 InteractionTrace. Structural shape only here; OS-011 is authoritative.",
      "required": ["trace_id", "edges"],
      "properties": {
        "trace_id": { "type": "string", "format": "uuid" },
        "edges":    { "type": "array", "minItems": 1 }
      }
    },
    "proof":          { "$ref": "https://opensentience.org/spec/proof-result/v0.1" },
    "evidence":       { "$ref": "https://opensentience.org/spec/evidence-bundle/v0.1" },
    "content_hash":   { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "signature":      { "type": ["string", "null"], "default": null }
  },
  "additionalProperties": false
}
